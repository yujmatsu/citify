{
  "name": "citify-demo-video",
  "version": "1.0.0",
  "private": true,
  "description": "Citify 提出用デモ動画 (Remotion)。画面録画にテロップ/字幕/ナレーション(voicebox WAV)を重畳する編集プロジェクト。",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render CitifyDemo out/citify-demo.mp4",
    "render:high": "remotion render CitifyDemo out/citify-demo.mp4 --crf 16 --concurrency 50%",
    "still": "remotion still CitifyDemo out/frame.png --frame 30",
    "upgrade": "remotion upgrade",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
