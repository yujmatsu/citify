# =============================================================================
# Citify 環境変数テンプレート
# =============================================================================
# このファイルは Git にコミットされる「公開テンプレート」です。
# 実値は `.env.local` (または .env.development / .env.production) にコピーして
# 設定してください。`.env*` は .gitignore で除外されます。
#
# Secret Manager 推奨マーク (🔒) のキーは、本番では Secret Manager に格納し、
# Cloud Run の --set-secrets 経由で注入してください。
# =============================================================================

# ----- 基本 (apps/api) -------------------------------------------------------
# Cloud Run / FastAPI が読み取る基本設定
APP_VERSION=0.1.0-dev
ENV=dev                                # dev | staging | prod
PORT=8080                              # Cloud Run が自動注入、ローカル時のみ指定
CORS_ORIGINS=http://localhost:3000     # 本番は https://citify.example.com に限定
GIT_SHA=                               # Cloud Build が自動注入 (空でOK)

# ----- GCP 基本 ---------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=citify-dev        # dev=citify-dev / prod=citify-prod (Week 5+)
GCP_REGION=asia-northeast1             # 全リソース統一 (Tokyo)
# ローカル開発時のみ ADC ファイルを指定 (Cloud Run 上では使用しない)
# GOOGLE_APPLICATION_CREDENTIALS=/home/yujmatsu/.config/gcloud/application_default_credentials.json

# ----- AI / Vertex AI ---------------------------------------------------------
VERTEX_AI_LOCATION=asia-northeast1
VERTEX_RAG_CORPUS_ID=                  # Week 1 で発行された corpus resource name を入れる
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
# 🔒 ローカル開発で REST API キー使用時のみ (本番は Vertex AI ADC 経由推奨)
# GEMINI_API_KEY=AIza...

# ----- データストア -----------------------------------------------------------
FIRESTORE_DATABASE=(default)           # Firestore Native mode、Week 1 で作成
BIGQUERY_DATASET_RAW=citify_raw        # 生データ (議事録・プレス)
BIGQUERY_DATASET_MART=citify_mart      # 集計済 (フィード用)
GCS_BUCKET_MEDIA=citify-dev-media      # Veo/Imagen 生成物
GCS_BUCKET_RAW=citify-dev-raw          # スクレイピング生データ

# ----- メッセージング ---------------------------------------------------------
PUBSUB_TOPIC_INGEST=citify-ingest
PUBSUB_TOPIC_TRANSLATE=citify-translate
PUBSUB_TOPIC_DISTRIBUTE=citify-distribute

# ----- スクレイピング ---------------------------------------------------------
# 国会会議録 API は鍵不要、レート制限 1 sec 間隔
KOKKAI_API_BASE=https://kokkai.ndl.go.jp/api/speech
SCRAPER_USER_AGENT=CitifyBot/0.1 (+https://citify.example.com)
SCRAPER_INTERVAL_SEC=2                 # 同一サーバへの最小間隔 (倫理)

# ----- フロントエンド (apps/web、Week 3 で本格使用) --------------------------
# Next.js は NEXT_PUBLIC_ プレフィックスのみクライアント露出
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_PROJECT_ID=citify-dev
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=citify-dev.firebaseapp.com
# 🔒 Firebase Web SDK 用 API キー (公開可だが Cloud Console で domain 制限必須)
NEXT_PUBLIC_FIREBASE_API_KEY=

# ----- 観測性 -----------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
CLOUD_TRACE_ENABLED=true               # Cloud Trace export

# ----- フィーチャーフラグ -----------------------------------------------------
# 機能の段階的有効化 (倫理違反検出時は false にして即停止)
FEATURE_VEO_ENABLED=false              # Week 4 で true に
FEATURE_IMAGEN_ENABLED=false           # Week 4 で true に
FEATURE_COMPARE_VIEW=false             # Week 4 (B-2) で true に
FEATURE_NOTIFICATIONS=false            # Week 5 (B-5) で true に
